# Copy to .env before: docker compose up -d

# Azure DevOps PAT (Packaging read on omni-backend) — required for first image build
FEED_ACCESSTOKEN=

# Cosmos — optional when using docker-compose cosmos-emulator (default below is applied if unset)
# In Docker network (back-office container → emulator):
# ConnectionStrings__priceconfigurator=AccountEndpoint=http://cosmos-emulator:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
#
# From host (dotnet run) with emulator in Docker — port 18081:
# ConnectionStrings__priceconfigurator=AccountEndpoint=http://localhost:18081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
#
# Windows Cosmos Emulator on host (API in Docker):
# ConnectionStrings__priceconfigurator=AccountEndpoint=https://host.docker.internal:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==

# ConnectionStrings__priceconfigurator=

AuthScriptsApi_Url=https://auth-scripts-api.dev.nobiadigital.com
PublicConfiguratorBaseUrl=https://price-configurator-magnet.dev.nobiadigital.com
# Cloudinary Media Library (CMS card images). Copy key/secret from kitchen-quiz-backoffice or your vault.
CloudinaryName=dgg9enyjv
CloudinaryKey=
CloudinarySecret=
CloudinaryLogin=false
# Must be "local" for Docker/local — avoids Azure DataProtection storage (see launchSettings.json)
ASPNETCORE_ENVIRONMENT=local
