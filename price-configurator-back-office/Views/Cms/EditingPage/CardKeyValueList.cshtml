@model IEditingPageField<string>

@{
    var readOnly = Model.Property.IsReadOnly;
}

<div class="card-kv-editor"
     data-card-kv-editor
     data-readonly="@readOnly.ToString().ToLowerInvariant()">
    <div class="alert alert-warning py-2 small d-none mb-2" data-kv-parse-error role="alert">
        Saved data for this field is not valid JSON. It was not loaded into the editor; saving other changes may overwrite it. Fix the raw value or re-import from seed.
    </div>
    <div class="alert alert-warning py-2 small d-none mb-2" data-kv-duplicate-keys role="alert"></div>
    <input type="hidden"
           id="@Model.Name"
           name="@Model.Name"
           data-card-json
           value="@Model.Value" />

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Label</th>
                    <th class="card-kv-key-cell">Key</th>
                    <th class="text-end" style="width: 9rem">Actions</th>
                </tr>
            </thead>
            <tbody data-kv-rows></tbody>
        </table>
    </div>

    @if (!readOnly)
    {
        <button type="button" class="btn btn-beta btn-sm mt-2" data-kv-add>+ Add option</button>
        <p class="form-text text-muted mb-0 mt-2">
            Each row is one selectable option. <strong>Key</strong> must match the index used in price tables (usually 0, 1, 2…).
        </p>
    }
</div>
