@model IEditingPageField<string>

@{
    var readOnly = Model.Property.IsReadOnly;
}

<div class="card-images-editor"
     data-card-images-editor
     data-readonly="@readOnly.ToString().ToLowerInvariant()">
    <div class="alert alert-warning py-2 small d-none mb-2" data-img-parse-error role="alert">
        Saved image data is not valid JSON. It was not loaded into the editor; fix the data or re-import from seed before saving other fields.
    </div>
    <div class="alert alert-info py-2 small d-none mb-2" data-img-no-sinks role="alert">
        Define <strong>Sinks</strong> above first, then set one image path per sink option.
    </div>
    <input type="hidden"
           id="@Model.Name"
           name="@Model.Name"
           data-card-json
           value="@Model.Value" />

    <p class="form-text text-muted mb-2">
        One image per sink bowl option. Rows follow the <strong>Sinks</strong> list order above.
    </p>

    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Sink option</th>
                    <th>Cloudinary path</th>
                </tr>
            </thead>
            <tbody data-img-rows></tbody>
        </table>
    </div>

    @if (!readOnly)
    {
        <button type="button" class="btn btn-beta btn-sm mt-2" data-img-sync-sinks>Refresh rows from sinks</button>
    }
</div>
